# -------------------------------------------------------
# AKS Metrics Assistant - Phase 1
# Copy this file to .env for local development only.
# NEVER commit .env to source control.
# In production, use Kubernetes Secrets.
# -------------------------------------------------------

# -------------------------------------------------------
# PROMETHEUS SOURCES
# App reads these individual variables when PROMETHEUS_SOURCES is empty.
# Use PROMETHEUS_SOURCES only if you need a custom JSON source list.
# -------------------------------------------------------
PROMETHEUS_SOURCES=

# Local / in-cluster Prometheus (on-prem VMs)
PROMETHEUS_NODE_NAME=Prometheus
PROMETHEUS_NODE_URL=http://192.168.100.230:9090
PROMETHEUS_NODE_AUTH_TYPE=basic
PROMETHEUS_NODE_USERNAME=REPLACE_USERNAME
PROMETHEUS_NODE_PASSWORD=REPLACE_PASSWORD
PROMETHEUS_NODE_DESCRIPTION=In-cluster Prometheus

# Azure Monitor Managed Prometheus (AKS)
PROMETHEUS_AKS_NAME=uat-monitor-workspace-prometheus
PROMETHEUS_AKS_URL=https://REPLACE_WORKSPACE_NAME.canadacentral.prometheus.monitor.azure.com
PROMETHEUS_AKS_AUTH_TYPE=azure_ad
PROMETHEUS_AKS_TENANT_ID=REPLACE_DIRECTORY_ID
PROMETHEUS_AKS_CLIENT_ID=REPLACE_APPLICATION_ID
PROMETHEUS_AKS_CLIENT_SECRET=REPLACE_CLIENT_SECRET_VALUE
PROMETHEUS_AKS_SUBSCRIPTION_ID=REPLACE_SUBSCRIPTION_ID
PROMETHEUS_AKS_DESCRIPTION=Azure Monitor Managed Prometheus

# AZURE MONITOR (management.azure.com REST API)

AZURE_RESOURCE_NAME=uat-monitor-workspace
AZURE_RESOURCE_TENANT_ID=REPLACE_DIRECTORY_ID
AZURE_RESOURCE_CLIENT_ID=REPLACE_APPLICATION_ID
AZURE_RESOURCE_CLIENT_SECRET=REPLACE_CLIENT_SECRET_VALUE
AZURE_RESOURCE_SUBSCRIPTION_ID=REPLACE_SUBSCRIPTION_ID
AZURE_RESOURCE_DESCRIPTION=Azure Monitor Workspace

# -------------------------------------------------------
# Prometheus query settings
# -------------------------------------------------------
PROMETHEUS_TIMEOUT_SECONDS=10
PROMETHEUS_MAX_RESULTS=100
PROMETHEUS_DEFAULT_RANGE=24h
ALLOWED_RANGES=1h,6h,12h,24h,2d,7d

# -------------------------------------------------------
# Daily report scope
#
# DAILY_REPORT_SOURCES: comma-separated source names to include.
#   Use only Prometheus-compatible sources (type: aks or azure).
# DAILY_REPORT_NAMESPACES: comma-separated namespaces to monitor.
# -------------------------------------------------------
DAILY_REPORT_SOURCES=Prometheus,uat-monitor-workspace-prometheus
DAILY_REPORT_NAMESPACES=default,kube-system,monitoring

# -------------------------------------------------------
# Anthropic
# -------------------------------------------------------
ANTHROPIC_API_KEY=REPLACE_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# -------------------------------------------------------
# Microsoft Teams
# -------------------------------------------------------
TEAMS_WEBHOOK_URL=REPLACE_TEAMS_INCOMING_WEBHOOK_URL
TEAMS_OUTGOING_WEBHOOK_SECRET=REPLACE_TEAMS_OUTGOING_WEBHOOK_SECRET
TEAMS_ALERT_WEBHOOK_URL=REPLACE_TEAMS_ALERT_WEBHOOK_URL
ALERT_WEBHOOK_TOKEN=REPLACE_ALERT_WEBHOOK_TOKEN